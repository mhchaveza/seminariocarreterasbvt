---
import { NAV_LINKS } from "../consts";
---

<nav
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-outline-variant shadow-sm"
>
  <div class="max-w-[1280px] mx-auto flex items-center justify-between px-5 md:px-10 lg:px-16 h-24 md:h-28">
    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0" aria-label="Inicio - II Seminario Internacional">
      <img
        src="/images/logo-completo.png"
        alt="II Seminario Internacional de Carreteras de Bajo Volumen"
        class="h-16 md:h-20 w-auto object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <div class="hidden lg:flex items-center gap-7">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="font-label text-[13px] uppercase tracking-wider text-on-surface-variant hover:text-primary transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <div class="flex items-center gap-3 md:gap-4">
      <!-- Universidad de Medellín -->
      <a
        href="https://udemedellin.edu.co"
        target="_blank"
        rel="noopener"
        class="hidden md:flex flex-col items-center gap-0.5 shrink-0"
        aria-label="Universidad de Medellín - Vigilada Mineducación"
      >
        <img
          src="/images/logo-universidad-de-medellin.png"
          alt="Universidad de Medellín"
          class="h-12 md:h-14 w-auto object-contain"
          loading="eager"
        />
        <span class="font-label text-[8px] uppercase tracking-[0.18em] text-on-surface-variant">
          Vigilada Mineducación
        </span>
      </a>

      <!-- CTA -->
      <a
        href="/inscripcion"
        class="hidden sm:inline-flex items-center justify-center px-4 md:px-5 py-2.5 bg-tertiary-container text-on-tertiary-container font-label text-[13px] font-semibold uppercase tracking-wide rounded-md hover:bg-tertiary-fixed-dim transition-colors"
      >
        Preinscríbete
      </a>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="lg:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-primary hover:bg-surface-container-low transition-colors"
      >
        <span class="material-symbols-outlined" id="menu-icon">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-outline-variant bg-surface-container-lowest"
  >
    <div class="max-w-[1280px] mx-auto px-5 py-4 flex flex-col gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="block px-4 py-3 rounded-md font-label text-sm uppercase tracking-wider text-on-surface hover:bg-primary/5 hover:text-primary transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/inscripcion"
        class="mt-3 sm:hidden inline-flex items-center justify-center px-5 py-3 bg-tertiary-container text-on-tertiary-container font-label text-sm font-semibold uppercase tracking-wide rounded-md"
      >
        Preinscríbete
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("menu-toggle");
  const panel = document.getElementById("mobile-menu");
  const icon = document.getElementById("menu-icon");
  if (btn && panel && icon) {
    btn.addEventListener("click", () => {
      const isOpen = !panel.classList.contains("hidden");
      panel.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));
      icon.textContent = !isOpen ? "close" : "menu";
    });
    panel.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        panel.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        icon.textContent = "menu";
      }),
    );
  }
</script>
